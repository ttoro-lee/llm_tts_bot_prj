# 시스템 프롬프트 (비우면 미적용)
SYSTEM_PROMPT=

# LLM 설정
LLM_PROVIDER=ollama          # ollama (현재 지원)
LLM_MODEL=llama3.2           # ollama에서 pull한 모델명
OLLAMA_HOST=                 # 원격 Ollama 서버 주소 (기본값: http://localhost:11434)

# TTS 설정
TTS_PROVIDER=edge            # edge | pyttsx3
TTS_VOICE=ko-KR-SunHiNeural  # edge-tts 보이스 (edge 사용 시)
                             # 남성: ko-KR-InJoonNeural
TTS_RATE=150                 # 말하기 속도 (pyttsx3 사용 시)
TTS_VOLUME=1.0               # 볼륨 0.0~1.0 (pyttsx3 사용 시)
TTS_VOICE_ID=                # pyttsx3 보이스 ID (pyttsx3 사용 시, 비우면 시스템 기본값)
